<Window x:Class="TFCMessenger.NotificationPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="320"
        Height="80"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        FlowDirection="RightToLeft"
        MouseEnter="Window_MouseEnter"
        MouseLeave="Window_MouseLeave"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border Background="#2C2C2C"
            CornerRadius="12"
            Padding="12"
            BorderThickness="1"
            BorderBrush="#444444"
            Opacity="0.97">

        <Grid>
            <Grid.ColumnDefinitions>
                <!-- ستون آواتار -->
                <ColumnDefinition Width="Auto"/>
                <!-- ستون متن -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- آواتار گرد سمت راست -->
            <Border Grid.Column="0"
                    Width="48"
                    Height="48"
                    CornerRadius="24"
                    ClipToBounds="True"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Margin="0,0,12,0"
                    Background="#3A3A3A">
                <Image x:Name="imgAvatar"
                       Stretch="UniformToFill"/>
            </Border>

            <!-- متن کاملاً راست‌چین و وسط چین عمودی -->
            <StackPanel Grid.Column="1"
                        Orientation="Vertical"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Stretch"
                        Margin="0,0,0,0">

                <!-- نام فرستنده -->
                <TextBlock x:Name="txtSender"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="#FFFFFF"
                           TextAlignment="Left"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="220"
                           VerticalAlignment="Center"/>

                <!-- متن پیام -->
                <TextBlock x:Name="txtMessage"
                           FontSize="13"
                           Foreground="#E0E0E0"
                           TextWrapping="Wrap"
                           TextAlignment="Left"
                           TextTrimming="CharacterEllipsis"
                           MaxHeight="48"
                           MaxWidth="220"
                           LineHeight="18"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>