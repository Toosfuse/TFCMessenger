<Window x:Class="TFCMessenger.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="TFCMessenger" Height="768" Width="1024">

    <Grid>
        <wv2:WebView2 x:Name="webView" Grid.Row="1" Visibility="Collapsed"/>
        <Grid x:Name="loadingPanel" Background="#1a1a2e">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="TFC Messenger" FontSize="32" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Foreground="#667eea"/>
                <TextBlock Text="در حال بارگذاری..." FontSize="14" Foreground="#999" HorizontalAlignment="Center" Margin="0,15,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>

</Window>
